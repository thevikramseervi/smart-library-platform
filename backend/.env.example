# Database — local Docker Compose
DATABASE_URL=postgresql+psycopg://smart_library:smart_library@localhost:5432/smart_library

# Database — Neon (staging/production)
# DATABASE_URL=postgresql+psycopg://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (JSON array — must include your frontend origin)
CORS_ORIGINS=["http://localhost:5173"]

# Circulation business rules (optional — defaults shown)
LOAN_PERIOD_DAYS=14
RESERVATION_EXPIRY_DAYS=7
DAILY_OVERDUE_FINE_RATE=10.00

# Cloudflare R2 — planned for digital resources (Sprint 5+)
CLOUD_STORAGE_BUCKET=
CLOUD_STORAGE_KEY=
CLOUD_STORAGE_SECRET=
CLOUD_STORAGE_ENDPOINT=

# Dev seed users (local development and testing only)
DEV_ADMIN_EMAIL=admin@library.local
DEV_ADMIN_PASSWORD=admin123456
DEV_ADMIN_FIRST_NAME=System
DEV_ADMIN_LAST_NAME=Admin

DEV_LIBRARIAN_EMAIL=librarian@library.local
DEV_LIBRARIAN_PASSWORD=librarian123456
DEV_LIBRARIAN_FIRST_NAME=Dev
DEV_LIBRARIAN_LAST_NAME=Librarian
