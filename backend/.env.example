# Database — local Docker Compose
DATABASE_URL=postgresql+psycopg://smart_library:smart_library@localhost:5432/smart_library

# Database — Neon (staging/production)
# DATABASE_URL=postgresql+psycopg://user:password@ep-xxx.region.aws.neon.tech/smart_library?sslmode=require

# JWT (used in Sprint 2)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# Cloudflare R2 (used in digital resources sprint)
CLOUD_STORAGE_BUCKET=
CLOUD_STORAGE_KEY=
CLOUD_STORAGE_SECRET=
CLOUD_STORAGE_ENDPOINT=

# Dev admin user (local development and testing only)
DEV_ADMIN_EMAIL=admin@library.local
DEV_ADMIN_PASSWORD=admin123456
DEV_ADMIN_FIRST_NAME=System
DEV_ADMIN_LAST_NAME=Admin
